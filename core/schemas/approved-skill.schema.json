    "id": { "type": "string" },
    "sourceCandidateId": { "type": "string" },
    "approvedBy": { "type": "string" },
    "approvedAt": { "type": "string" },
    "qaEvidence": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
